{
  "name": "reinvent-sessions-api",
  "version": "1.0.0",
  "description": "Express.js REST API for AWS re:Invent conference session management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "db:reset": "node db/reset.js",
    "start-all": "./start-dev.sh",
    "build": "./build-prod.sh",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build"
  },
  "keywords": [
    "express",
    "rest",
    "api",
    "sqlite",
    "conference"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "nodemon": "^3.0.2"
  }
}
